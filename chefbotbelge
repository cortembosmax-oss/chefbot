const express = require('express');
const fetch = require('node-fetch');
const path = require('path');
const app = express();

app.use(express.json());
app.use(express.static(path.join(__dirname, 'public')));

// Ta clé API Anthropic — remplace ici
const ANTHROPIC_API_KEY = 'sk-ant-METS-TA-CLE-ICI';

app.post('/api/chat', async (req, res) => {
  try {
    const { messages, systemPrompt } = req.body;

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': ANTHROPIC_API_KEY,
        'anthropic-version': '2023-06-01',
        'anthropic-beta': 'web-search-2025-03-05'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1500,
        system: systemPrompt,
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        messages: messages
      })
    });

    const data = await response.json();
    res.json(data);

  } catch (err) {
    console.error(err);
    res.status(500).json({ error: err.message });
  }
});

// Gestion des tool_use multi-tours côté serveur
app.post('/api/chat/full', async (req, res) => {
  try {
    const { conversationHistory, systemPrompt } = req.body;

    let messages = [...conversationHistory];
    let finalReply = '';
    let searchQueries = [];
    const maxTurns = 4;

    for (let turn = 0; turn < maxTurns; turn++) {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': ANTHROPIC_API_KEY,
          'anthropic-version': '2023-06-01',
          'anthropic-beta': 'web-search-2025-03-05'
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1500,
          system: systemPrompt,
          tools: [{ type: 'web_search_20250305', name: 'web_search' }],
          messages: messages
        })
      });

      const data = await response.json();
      const content = data.content || [];

      for (const block of content) {
        if (block.type === 'text') finalReply += block.text;
        if (block.type === 'tool_use' && block.name === 'web_search') {
          searchQueries.push(block.input?.query || '');
        }
      }

      if (data.stop_reason !== 'tool_use') break;

      const toolResults = content
        .filter(b => b.type === 'tool_use')
        .map(b => ({ type: 'tool_result', tool_use_id: b.id, content: 'Recherche effectuée.' }));

      messages = [
        ...messages,
        { role: 'assistant', content: content },
        { role: 'user', content: toolResults }
      ];
      finalReply = '';
    }

    res.json({ reply: finalReply, searchQueries });

  } catch (err) {
    console.error(err);
    res.status(500).json({ error: err.message });
  }
});

const PORT = 3000;
app.listen(PORT, () => {
  console.log(`\n🍳 ChefBot Belge tourne sur http://localhost:${PORT}\n`);
});
